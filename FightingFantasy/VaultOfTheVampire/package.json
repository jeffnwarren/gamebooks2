{
  "name": "vault-of-the-vampire",
  "scripts": {
    "check": "npm run check:js && npm run check:data && npm run check:intro && npm run check:ocr && npm run check:fixtures && npm run check:winnable",
    "check:choices": "node tools/check-choices.js",
    "check:data": "node tools/check-data.js",
    "check:fixtures": "node tools/check-fixtures.js",
    "check:intro": "node tools/check-intro.js",
    "check:js": "node --check playable/app.js",
    "check:ocr": "node tools/check-ocr-smoke.js",
    "check:winnable": "node tools/check-winnable.js",
    "report:graph": "node tools/check-data.js --verbose",
    "report:orphans": "node tools/report-orphans.js",
    "report:misroutes": "node tools/report-misroutes.js",
    "report:illustrations": "python ../tools/detect-full-page-illustrations.py .",
    "build:illustrations": "python ../tools/detect-full-page-illustrations.py . --write --extract",
    "embed:illustration-sections": "node tools/embed-illustration-sections.js",
    "report:ocr": "node tools/report-ocr.js"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
